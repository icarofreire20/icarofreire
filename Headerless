<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Messenger</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        #chat-window {
            border: 1px solid #ccc;
            padding: 10px;
            height: 300px;
            overflow-y: scroll;
            margin-bottom: 10px;
            background-color: #f9f9f9;
        }
        .message-sent { text-align: right; color: blue; }
        .message-received { text-align: left; color: green; }
        .message-timestamp { font-size: 0.8em; color: #888; }
        #message-input { width: calc(100% - 70px); padding: 8px; margin-right: 5px; }
        #send-button { padding: 8px 15px; }
    </style>
</head>
<body>
    <h1>Genesys Web Messenger</h1>

    <div id="chat-window">
        </div>

    <div>
        <textarea id="message-input" placeholder="Digite sua mensagem..."></textarea>
        <button id="send-button">Enviar</button>
    </div>

	<script type="text/javascript" charset="utf-8">
	  (function (g, e, n, es, ys) {
		g['_genesysJs'] = e;
		g[e] = g[e] || function () {
		  (g[e].q = g[e].q || []).push(arguments)
		};
		g[e].t = 1 * new Date();
		g[e].c = es;
		ys = document.createElement('script'); ys.async = 1; ys.src = n; ys.charset = 'utf-8'; document.head.appendChild(ys);
	  })(window, 'Genesys', 'https://apps.usw2.pure.cloud/genesys-bootstrap/genesys.min.js', {
		environment: 'prod-usw2',
		deploymentId: 'ad23042d-1951-49e7-8bcb-d58820c744c0'
	  });
	</script>
	
    <script>
        const chatWindow = document.getElementById('chat-window');
		const messageInput = document.getElementById('message-input');
		const sendButton = document.getElementById('send-button');

		// Função para exibir mensagens na tela
		function displayMessage(messageText, direction) {
			const messageElement = document.createElement('div');
			// Define a classe CSS com base na direção da mensagem
			// Se a direção for "Inbound", é uma mensagem enviada por este usuário
			messageElement.classList.add(direction === 'Inbound' ? 'message-sent' : 'message-received');

			const timestamp = new Date().toLocaleTimeString();
			messageElement.innerHTML = `<div>${messageText}</div><div class="message-timestamp">${timestamp}</div>`;
			chatWindow.appendChild(messageElement);
			chatWindow.scrollTop = chatWindow.scrollHeight; // Rola para a última mensagem
		}

		// Função para enviar a mensagem
		sendButton.addEventListener('click', () => {
			const inputed_message = messageInput.value.trim();
			if (inputed_message) {
				// Exibe a mensagem do usuário imediatamente na interface como 'Inbound' (enviada por este cliente)
				displayMessage(inputed_message, 'Inbound');

				Genesys("command", "MessagingService.sendMessage", {
					message: inputed_message
				},
				function() {
					console.log("Mensagem enviada com sucesso!", inputed_message);
				},
				function() {
					console.error("Erro ao enviar mensagem!");
					// Opcional: pode adicionar um feedback visual de erro aqui
				});

				messageInput.value = ''; // Limpa o campo de texto
			}
		});

		// Permite enviar mensagem ao pressionar Enter
		messageInput.addEventListener('keypress', (e) => {
			if (e.key === 'Enter' && !e.shiftKey) { // Garante que não é um Shift+Enter
				e.preventDefault(); // Evita a quebra de linha no textarea
				sendButton.click(); // Simula o clique no botão de enviar
			}
		});

		// Evento para registrar as mensagens recebidas
		Genesys("subscribe", "MessagingService.messagesReceived", function({ data }) {
			console.log("Dados de mensagem recebidos:", data);

			// Verifica se há mensagens no array 'messages'
			if (data && data.messages && Array.isArray(data.messages)) {
				data.messages.forEach(message => {
					// Verifica se a mensagem tem 'text' e 'direction'
					// E, **importante**: só exibe se a direção for 'Outbound'
					if (message.text && message.direction === 'Outbound') {
						displayMessage(message.text, message.direction);
					}
					// Mensagens com direction 'Inbound' não serão exibidas
				});
			}
		});
    </script>
	
	<script>
	Genesys("subscribe", "MessagingService.ready", function(){console.log("pronto para usar")});
    </script>
	<script>
		Genesys("command", "Database.set", {
			messaging: {
			customAttributes: {
				department: "sales",
				property_type: "apartment",
				VM:"VM",
				email: "email@mobile.online"
			}
		  }
		});
	</script>
	
</body>
</html>
